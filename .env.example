# Example environment for the infrastructure Config API.
# Copy to `.env` and adjust. Every value below is the default, so an empty .env
# runs the service as-is (MongoDB on localhost, auth disabled / open).

# --- Service settings (app/v1/config/conf.py) --------------------------------
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=infrastructure_governor
# Collection keyed by `doc_type`: enterprise_configuration / naming_conventions / project_registry
MONGO_COLLECTION=global_configs
# Background loop interval (s): syncs the live allowlists + invalidates the cached OpenAPI schema.
POLL_INTERVAL_SECONDS=5
# In-memory cache TTL (s) for resolved config / naming / project-registry lookups.
CACHE_TTL_SECONDS=60
API_PREFIX=/api/v1/infra
API_TITLE=Infrastructure Config API

# --- SSO protection (generic OIDC, provided by tashtiot-apis-library) ---------
# These knobs are read by the *library's* settings, not by conf.py.
# Auth is OFF by default — the service runs open (backward compatible). To PROTECT
# the API with SSO, set AUTH_ENABLED=true and point AUTH_OIDC_ISSUER at your
# provider's issuer URL. The library discovers the provider's JWKS from
# <issuer>/.well-known/openid-configuration at startup and verifies inbound bearer
# JWTs against those keys (cached AUTH_JWKS_CACHE_TTL seconds) — no per-request
# call to the SSO server. AUTH_OIDC_ISSUER also becomes the expected `iss`.
AUTH_ENABLED=false
# AUTH_OIDC_ISSUER=https://sso.example.com/realms/platform
# AUTH_AUDIENCE=config-api
# AUTH_ALGORITHMS=["RS256"]
# AUTH_JWKS_CACHE_TTL=3600
# AUTH_OIDC_TIMEOUT=10.0
# Explicit JWKS endpoint if your provider's path is non-standard (skips discovery):
# AUTH_JWKS_URL=https://sso.example.com/realms/platform/protocol/openid-connect/certs

# Alternative verification materials — exactly ONE material may be configured when
# AUTH_ENABLED=true (the OIDC issuer above, a JWKS URL, a public key, or an HS256
# secret); setting more than one fails fast at startup. Normally unused with SSO.
# AUTH_PUBLIC_KEY_PEM="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
# AUTH_PUBLIC_KEY_PATH=/etc/secrets/jwt_pub.pem
# AUTH_HS256_SECRET=replace-with-a-32-byte-or-longer-secret

# Request header carrying the bearer token.
# AUTH_HEADER_NAME=Authorization

# Path prefixes/regexes that bypass auth (probes/metrics/openapi are always
# excluded automatically). JSON array.
# AUTH_EXCLUDE_PATHS=["/health","/metrics","/static","/docs","/openapi.json","/liveness","/readiness"]
